</style>

<script>
  // гғ’гғјгғӯгғјгӮ»гӮҜгӮ·гғ§гғігҒ®гӮ№гғ©гӮӨгғүгӮ·гғ§гғјж©ҹиғҪ
  document.addEventListener("DOMContentLoaded", function () {
    const slides = document.querySelectorAll(".hero-slide");
    const paginationDots = document.querySelectorAll(".pagination-stripe");
    const searchBtn = document.querySelector(".hero-search-btn");
    let currentSlide = 0;
    let slideInterval: ReturnType<typeof setInterval> | undefined;

    // гғҮгғҗгғғгӮ°жғ…е ұ
    console.log("гӮ№гғ©гӮӨгғүж•°:", slides.length);
    console.log("гғҡгғјгӮёгғҚгғјгӮ·гғ§гғігғүгғғгғҲж•°:", paginationDots.length);
    console.log("жӨңзҙўгғңгӮҝгғі:", searchBtn);

    // гӮ№гғ©гӮӨгғүгӮ’еҲҮгӮҠжӣҝгҒҲгӮӢй–ўж•°
    function showSlide(index: number) {
      // гҒҷгҒ№гҒҰгҒ®гӮ№гғ©гӮӨгғүгӮ’йқһгӮўгӮҜгғҶгӮЈгғ–гҒ«гҒҷгӮӢ
      slides.forEach((slide) => slide.classList.remove("active"));
      paginationDots.forEach((dot) => dot.classList.remove("active"));

      // жҢҮе®ҡгҒ•гӮҢгҒҹгӮ№гғ©гӮӨгғүгӮ’гӮўгӮҜгғҶгӮЈгғ–гҒ«гҒҷгӮӢ
      if (slides[index]) {
        slides[index].classList.add("active");
      }
      if (paginationDots[index]) {
        paginationDots[index].classList.add("active");
      }

      currentSlide = index;
    }

    // ж¬ЎгҒ®гӮ№гғ©гӮӨгғүгҒ«з§»еӢ•
    function nextSlide() {
      const nextIndex = (currentSlide + 1) % slides.length;
      showSlide(nextIndex);
    }

    // иҮӘеӢ•гӮ№гғ©гӮӨгғүй–Ӣе§Ӣ
    function startSlideShow() {
      slideInterval = setInterval(nextSlide, 5000); // 5з§’й–“йҡ”
    }

    // иҮӘеӢ•гӮ№гғ©гӮӨгғүеҒңжӯў
    function stopSlideShow() {
      clearInterval(slideInterval);
    }

    // гғҡгғјгӮёгғҚгғјгӮ·гғ§гғігӮ№гғҲгғ©гӮӨгғ—гҒ®гӮҜгғӘгғғгӮҜгӮӨгғҷгғігғҲ
    paginationDots.forEach((stripe, index) => {
      stripe.addEventListener("click", () => {
        showSlide(index);
        stopSlideShow();
        startSlideShow(); // еҶҚй–Ӣ
      });
    });

    // жӨңзҙўгғңгӮҝгғігҒ®гӮҜгғӘгғғгӮҜгӮӨгғҷгғігғҲ
    searchBtn?.addEventListener("click", () => {
      // гӮөгғӯгғідёҖиҰ§гӮ»гӮҜгӮ·гғ§гғігҒ«гӮ№гӮҜгғӯгғјгғ«
      const salonsSection = document.getElementById("salons");
      if (salonsSection) {
        salonsSection.scrollIntoView({ behavior: "smooth" });
      }
    });

    // гғһгӮҰгӮ№гғӣгғҗгғјгҒ§иҮӘеӢ•гӮ№гғ©гӮӨгғүгӮ’дёҖжҷӮеҒңжӯў
    const heroSection = document.querySelector(".hero-section");
    heroSection?.addEventListener("mouseenter", stopSlideShow);
    heroSection?.addEventListener("mouseleave", startSlideShow);

    // жңҖеҲқгҒ®гӮ№гғ©гӮӨгғүгӮ’иЎЁзӨә
    if (slides.length > 0) {
      showSlide(0);
    }

    // иҮӘеӢ•гӮ№гғ©гӮӨгғүй–Ӣе§Ӣ
    startSlideShow();

    // гғҳгӮўгӮ«гӮҝгғӯгӮ°: JSONгӮ’еҸ–еҫ—гҒ—гҒҰжҸҸз”» + гӮҝгғ–гғ•гӮЈгғ«гӮҝ
    type HairstyleItem = {
      id: number;
      hairType: string;
      imageUrl: string;
      alt: string;
    };
    let hairstyleItems: HairstyleItem[] = [];
    let currentCategory = "all";
    let currentDisplayCount = 12; // еҲқжңҹиЎЁзӨәд»¶ж•°
    const ITEMS_PER_LOAD = 12; // иҝҪеҠ иӘӯгҒҝиҫјгҒҝд»¶ж•°

    function renderHairstyles(items: HairstyleItem[]) {
      console.log("renderHairstylesе‘јгҒіеҮәгҒ—:", items.length, "д»¶");
      const grid = document.getElementById("hairstyle-grid");
      if (!grid) {
        console.error("hairstyle-gridиҰҒзҙ гҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“");
        return;
      }

      grid.innerHTML = "";
      const frag = document.createDocumentFragment();

      items.forEach((item, index) => {
        console.log(`гӮўгӮӨгғҶгғ ${index}:`, item.hairType, item.imageUrl);
        const wrapper = document.createElement("div");
        wrapper.className = "hairstyle-item";
        wrapper.setAttribute("data-hair-type", item.hairType);

        const img = document.createElement("img");
        img.src = item.imageUrl;
        img.alt = item.alt || "гғҳгӮўгӮ№гӮҝгӮӨгғ«";
        img.className = "hairstyle-image";

        wrapper.appendChild(img);
        frag.appendChild(wrapper);
      });

      grid.appendChild(frag);
      console.log(
        "гғҳгӮўгӮ№гӮҝгӮӨгғ«гӮ°гғӘгғғгғүжӣҙж–°е®ҢдәҶ:",
        grid.children.length,
        "еҖӢгҒ®иҰҒзҙ ",
      );
    }

    function applyHairstyleFilter(
      category: string,
      resetCount: boolean = true,
    ) {
      console.log("гғҳгӮўгӮ№гӮҝгӮӨгғ«гғ•гӮЈгғ«гӮҝйҒ©з”Ё:", category);
      currentCategory = category;

      if (resetCount) {
        currentDisplayCount = 12; // гӮҝгғ–еҲҮгӮҠжӣҝгҒҲжҷӮгҒҜгғӘгӮ»гғғгғҲ
      }

      let filteredItems: HairstyleItem[];

      if (category === "all") {
        filteredItems = hairstyleItems;
      } else {
        filteredItems = hairstyleItems.filter((i) => i.hairType === category);
      }

      // иЎЁзӨәд»¶ж•°гӮ’еҲ¶йҷҗ
      const displayItems = filteredItems.slice(0, currentDisplayCount);

      console.log(
        `гғ•гӮЈгғ«гӮҝзөҗжһң: ${displayItems.length}д»¶иЎЁзӨә (е…Ё${filteredItems.length}д»¶дёӯ)`,
      );
      renderHairstyles(displayItems);

      // гӮӮгҒЈгҒЁиҰӢгӮӢгғңгӮҝгғігҒ®иЎЁзӨәеҲ¶еҫЎ
      updateMoreButton(filteredItems.length > currentDisplayCount);
    }

    function updateMoreButton(hasMore: boolean) {
      const moreBtn = document.querySelector(
        ".hairstyle-more-btn",
      ) as HTMLElement;
      if (moreBtn) {
        if (hasMore) {
          moreBtn.style.display = "flex";
        } else {
          moreBtn.style.display = "none";
        }
      }
    }

    function loadMoreHairstyles() {
      currentDisplayCount += ITEMS_PER_LOAD;
      applyHairstyleFilter(currentCategory, false);
    }

    fetch("/data/hairstyles.index.json")
      .then((r) => r.json())
      .then((data: HairstyleItem[]) => {
        hairstyleItems = Array.isArray(data) ? data : [];
        console.log(
          "гғҳгӮўгӮ№гӮҝгӮӨгғ«гғҮгғјгӮҝиӘӯгҒҝиҫјгҒҝе®ҢдәҶ:",
          hairstyleItems.length,
          "д»¶",
        );
        // еҲқжңҹиЎЁзӨәгҒҜALLгӮҝгғ–гҒ§иЎЁзӨә
        applyHairstyleFilter("all");
      })
      .catch((err) => {
        console.error("гғҳгӮўгӮ№гӮҝгӮӨгғ«JSONиӘӯиҫјеӨұж•—", err);
        // гӮЁгғ©гғјжҷӮгӮӮALLгӮҝгғ–гҒ§иЎЁзӨәпјҲз©әй…ҚеҲ—пјү
        applyHairstyleFilter("all");
      });

    const hairstyleTabs = document.querySelectorAll(".hairstyle-tab");
    console.log("гғҳгӮўгӮ№гӮҝгӮӨгғ«гӮҝгғ–ж•°:", hairstyleTabs.length);

    hairstyleTabs.forEach((tab, index) => {
      console.log(
        `гӮҝгғ–${index}:`,
        tab.textContent,
        "data-category:",
        (tab as HTMLElement).dataset.category,
      );

      tab.addEventListener("click", (e) => {
        e.preventDefault();
        console.log("гӮҝгғ–гӮҜгғӘгғғгӮҜгӮӨгғҷгғігғҲзҷәзҒ«:", tab.textContent);

        // гҒҷгҒ№гҒҰгҒ®гӮҝгғ–гҒӢгӮүactiveгӮҜгғ©гӮ№гӮ’еүҠйҷӨ
        hairstyleTabs.forEach((t) => t.classList.remove("active"));
        // гӮҜгғӘгғғгӮҜгҒ•гӮҢгҒҹгӮҝгғ–гҒ«activeгӮҜгғ©гӮ№гӮ’иҝҪеҠ 
        tab.classList.add("active");

        const category = (tab as HTMLElement).dataset.category || "all";
        console.log("йҒёжҠһгҒ•гӮҢгҒҹгӮ«гғҶгӮҙгғӘ:", category);
        console.log("зҸҫеңЁгҒ®гғҳгӮўгӮ№гӮҝгӮӨгғ«гӮўгӮӨгғҶгғ ж•°:", hairstyleItems.length);
        applyHairstyleFilter(category, true); // гӮҝгғ–еҲҮгӮҠжӣҝгҒҲжҷӮгҒҜгғӘгӮ»гғғгғҲ
      });
    });

    // гӮӮгҒЈгҒЁиҰӢгӮӢгғңгӮҝгғігҒ®гӮӨгғҷгғігғҲгғӘгӮ№гғҠгғј
    const moreBtn = document.querySelector(".hairstyle-more-btn");
    if (moreBtn) {
      moreBtn.addEventListener("click", (e) => {
        e.preventDefault();
        console.log("гӮӮгҒЈгҒЁиҰӢгӮӢгғңгӮҝгғігӮҜгғӘгғғгӮҜ");
        loadMoreHairstyles();
      });
    }

    // гӮЁгғӘгӮўгӮ»гғ¬гӮҜгӮҝгғјпјҡгӮўгӮігғјгғҮгӮЈгӮӘгғіж©ҹиғҪпјҲPC/SPе…ұйҖҡпјү
    const prefectureButtons = document.querySelectorAll(".area-prefecture-btn");
    prefectureButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const prefecture = btn.closest(".area-prefecture");
        if (!prefecture) return;
        prefecture.classList.toggle("is-open");
      });
    });

    // еёӮеҢәз”әжқ‘гӮҜгғӘгғғгӮҜгҒ§гғ•гӮЈгғ«гӮҝиЎЁзӨә
    const cityButtons = document.querySelectorAll(".area-city");
    cityButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        // activeгӮҜгғ©гӮ№гҒ®еҲҮгӮҠжӣҝгҒҲ
        cityButtons.forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");

        const citySlug = (btn as HTMLElement).dataset.citySlug || "";
        const prefSlug = (btn as HTMLElement).dataset.prefectureSlug || "";
        showSalonsByCity(prefSlug, citySlug);
      });
    });

    // гӮөгғӯгғіиЎЁзӨәй–ўж•°
    const resultsSection = document.getElementById("salon-results");
    const resultsTitle = document.getElementById("salon-results-title");
    const allResultCards = document.querySelectorAll(".salon-result-card");

    function showSalonsByCity(prefSlug: string, citySlug: string) {
      if (!resultsSection) return;
      resultsSection.style.display = "block";

      // гӮҝгӮӨгғҲгғ«жӣҙж–°
      const cityBtn = document.querySelector(
        `[data-city-slug="${citySlug}"][data-prefecture-slug="${prefSlug}"]`,
      );
      const cityName = cityBtn?.textContent?.replace(/\s*\(\d+\)/, "") || "";
      if (resultsTitle) {
        resultsTitle.textContent = `гҖҢ${cityName}гҖҚеә—иҲ—дёҖиҰ§`;
      }

      // гӮ«гғјгғүиЎЁзӨәеҲҮгӮҠжӣҝгҒҲ
      allResultCards.forEach((card) => {
        const cardPref = (card as HTMLElement).dataset.prefecture || "";
        const cardChildren =
          (card as HTMLElement).dataset.prefectureChild || "";
        const childSlugs = cardChildren.split(",");
        const match = cardPref === prefSlug && childSlugs.includes(citySlug);
        (card as HTMLElement).style.display = match ? "" : "none";
      });

      resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    // гӮөгғӯгғіжӨңзҙўж©ҹиғҪ
    const salonSearchField = document.getElementById(
      "salon-search-input",
    ) as HTMLInputElement;
    const salonSearchButton = document.getElementById(
      "salon-search-btn",
    ) as HTMLButtonElement;

    function searchSalons() {
      const term = salonSearchField?.value.trim().toLowerCase();
      if (!term) {
        // жӨңзҙўгӮҜгғӘгӮў
        if (resultsSection) resultsSection.style.display = "none";
        allResultCards.forEach((card) => {
          (card as HTMLElement).style.display = "none";
        });
        return;
      }

      if (!resultsSection) return;
      resultsSection.style.display = "block";
      if (resultsTitle) {
        resultsTitle.textContent = `гҖҢ${salonSearchField.value.trim()}гҖҚеә—иҲ—дёҖиҰ§`;
      }

      allResultCards.forEach((card) => {
        const name = (card as HTMLElement).dataset.name?.toLowerCase() || "";
        const access =
          (card as HTMLElement).dataset.access?.toLowerCase() || "";
        const furigana =
          (card as HTMLElement).dataset.furigana?.toLowerCase() || "";
        const prefSlug = (card as HTMLElement).dataset.prefecture || "";
        const prefEl = document.querySelector(
          `[data-prefecture-slug="${prefSlug}"] .area-prefecture-name`,
        );
        const prefName = prefEl?.textContent?.toLowerCase() || "";
        const match =
          name.includes(term) ||
          access.includes(term) ||
          furigana.includes(term) ||
          prefName.includes(term);
        (card as HTMLElement).style.display = match ? "" : "none";
      });

      resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    salonSearchButton?.addEventListener("click", searchSalons);
    salonSearchField?.addEventListener("keypress", (e: KeyboardEvent) => {
      if (e.key === "Enter") searchSalons();
    });

    // гғӢгғҘгғјгӮ№гӮҝгғ–ж©ҹиғҪпјҲ.news-group гҒ®иЎЁзӨәеҲҮжӣҝпјү
    const newsTabs = document.querySelectorAll(".news-tab");
    const newsGroups = document.querySelectorAll(".news-group");
    newsTabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        // гҒҷгҒ№гҒҰгҒ®гӮҝгғ–гҒӢгӮүactiveгӮҜгғ©гӮ№гӮ’еүҠйҷӨ
        newsTabs.forEach((t) => t.classList.remove("active"));
        // гӮҜгғӘгғғгӮҜгҒ•гӮҢгҒҹгӮҝгғ–гҒ«activeгӮҜгғ©гӮ№гӮ’иҝҪеҠ 
        tab.classList.add("active");

        const category = (tab as HTMLElement).dataset.category;
        // гӮ°гғ«гғјгғ—гҒ®иЎЁзӨәеҲҮжӣҝ
        newsGroups.forEach((group) => {
          const groupCategory = (group as HTMLElement).dataset.category;
          (group as HTMLElement).style.display =
            groupCategory === category ? "block" : "none";
        });
      });
    });
  });
</script>
