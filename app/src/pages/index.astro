---
import Layout from "../layouts/Layout.astro";
import SalonCard from "../components/SalonCard.astro";
import NewsCard from "../components/NewsCard.astro";
import LocatorFilters from "../components/LocatorFilters.astro";
import Footer from "../components/Footer.astro";
import { componentClasses, responsive } from "../lib/design-system";
import type { SalonIndexData, News, Prefecture, InstagramItem } from "../types";

// гғўгғғгӮҜгғҮгғјгӮҝгӮ’гӮӨгғігғқгғјгғҲ
import prefecturesData from "../data/prefectures.json";
import { api } from "../lib/api";

// гӮөгғӯгғігғҮгғјгӮҝгӮ’иӘӯгҒҝиҫјгӮҖ
let salonData: any[] = [];
try {
  const fs = await import("fs");
  const path = await import("path");
  const salonDataPath = path.join(
    process.cwd(),
    "public",
    "data",
    "salons.index.json",
  );
  const salonDataContent = fs.readFileSync(salonDataPath, "utf-8");
  salonData = JSON.parse(salonDataContent);
} catch (error) {
  console.error("гӮөгғӯгғігғҮгғјгӮҝгҒ®иӘӯгҒҝиҫјгҒҝгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹ:", error);
  salonData = [];
}

// гӮөгғӯгғігғҮгғјгӮҝгӮ’зӣҙжҺҘдҪҝз”ЁпјҲеӨүжҸӣдёҚиҰҒпјү
const salons: SalonIndexData[] = salonData;

// гӮЁгғӘгӮўгӮ»гғ¬гӮҜгӮҝгғјз”ЁгғҮгғјгӮҝж§ӢйҖ гӮ’ж§ӢзҜү
const regionGroupDefs = [
  { name: "еҢ—жө·йҒ“гғ»жқұеҢ—гӮЁгғӘгӮў", slugs: ["hokkaido", "tohoku"] },
  { name: "й–ўжқұгӮЁгғӘгӮў", slugs: ["kanto"] },
  { name: "дёӯйғЁгӮЁгғӘгӮў", slugs: ["chubu"] },
  { name: "иҝ‘з•ҝгӮЁгғӘгӮў", slugs: ["kinki"] },
  { name: "дёӯеӣҪгғ»еӣӣеӣҪгӮЁгғӘгӮў", slugs: ["chugoku", "shikoku"] },
  { name: "д№қе·һгғ»жІ–зё„гӮЁгғӘгӮў", slugs: ["kyushu"] },
];

interface PrefectureGroup {
  name: string;
  slug: string;
  salons: SalonIndexData[];
  children: { name: string; slug: string; count: number }[];
}

interface RegionGroup {
  name: string;
  prefectures: PrefectureGroup[];
}

const regionGroups: RegionGroup[] = regionGroupDefs.map((def) => {
  const groupSalons = salons.filter((s) =>
    def.slugs.includes(s.region[0]?.slug),
  );
  const prefMap = new Map<string, PrefectureGroup>();

  groupSalons.forEach((salon) => {
    const prefName = salon.prefecture[0]?.name;
    const prefSlug = salon.prefecture[0]?.slug;
    if (!prefName) return;

    if (!prefMap.has(prefName)) {
      prefMap.set(prefName, {
        name: prefName,
        slug: prefSlug,
        salons: [],
        children: [],
      });
    }
    const pref = prefMap.get(prefName)!;
    pref.salons.push(salon);

    salon.prefecture_child.forEach((child) => {
      const existing = pref.children.find((c) => c.name === child.name);
      if (existing) {
        existing.count++;
      } else {
        pref.children.push({ name: child.name, slug: child.slug, count: 1 });
      }
    });
  });

  return {
    name: def.name,
    prefectures: Array.from(prefMap.values()),
  };
});

// NEWSгғҮгғјгӮҝгӮ’ prebuild з”ҹжҲҗжёҲгҒҝ JSON гҒӢгӮүиӘӯгҒҝиҫјгҒҝгҖҒгӮ«гғҶгӮҙгғӘеҲҘгҒ«еҲҶеүІ
let newsByCategory: { [key: string]: News[] } = {
  information: [],
  blog: [],
  movie: [],
};
try {
  const fs = await import("fs");
  const path = await import("path");
  const newsDataPath = path.join(
    process.cwd(),
    "public",
    "data",
    "news.index.json",
  );
  const raw = fs.readFileSync(newsDataPath, "utf-8");
  const items = (JSON.parse(raw) as News[]).map(
    ({ content, ...rest }) => rest as News,
  );
  const info: News[] = [];
  const blog: News[] = [];
  const movie: News[] = [];
  for (const n of items) {
    const cat = (n.categories?.[0] || "").toLowerCase();
    if (cat === "information" && info.length < 4) info.push(n);
    else if (cat === "blog" && blog.length < 4) blog.push(n);
    else if (cat === "movie" && movie.length < 4) movie.push(n);
    if (info.length === 4 && blog.length === 4 && movie.length === 4) break;
  }
  newsByCategory = { information: info, blog, movie };
} catch (error) {
  console.error("NEWSиӘӯгҒҝиҫјгҒҝгӮЁгғ©гғј:", error);
}

// InstagramгғҮгғјгӮҝгӮ’еҸ–еҫ—
let instagramItems: InstagramItem[] = [];
try {
  const result = await api.getInstagramItems({ per_page: 9 });
  instagramItems = result.success ? result.data : [];
} catch (error) {
  console.error("InstagramеҸ–еҫ—гӮЁгғ©гғј:", error);
  // гӮЁгғ©гғјгҒҢзҷәз”ҹгҒ—гҒҹе ҙеҗҲгҒ§гӮӮз©әй…ҚеҲ—гҒ§з¶ҷз¶ҡ
  instagramItems = [];
}

const prefectures: Prefecture[] = prefecturesData;

// жңҖж–°гҒ®гғӢгғҘгғјгӮ№3д»¶гӮ’еҸ–еҫ—пјҲINFORMATIONгӮ«гғҶгӮҙгғӘгҒӢгӮүпјү
const latestNews = newsByCategory.information.slice(0, 3);

// еә—иҲ—дёҖиҰ§гҒ®JSON-LDгӮ’з”ҹжҲҗпјҲгӮөгғӯгғігғҮгғјгӮҝгҒҜгӮҜгғ©гӮӨгӮўгғігғҲгӮөгӮӨгғүгҒ§иӘӯгҒҝиҫјгӮҖгҒҹгӮҒгҖҒгҒ“гҒ“гҒ§гҒҜз©әгҒ®й…ҚеҲ—пјү
const salonJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: [],
};

const unescapeHtml = (str: string) => {
  if (!str) return '';
  return str
    .replace(/&amp;/g, '&')
    .replace(/&#038;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#039;/g, "'");
};
