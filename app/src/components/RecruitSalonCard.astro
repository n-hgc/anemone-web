---
import type { SalonIndexData } from "../types";

export interface Props {
  salon: SalonIndexData;
}

const { salon } = Astro.props;

// 親子関係を考慮して都道府県とエリアを取得
// prefecture タクソノミー内で親ターム（parent === 0）と子ターム（parent > 0）を分ける
const prefectureTerms = salon.prefecture?.filter((p) => p.parent === 0) || [];
const areaTerms = salon.prefecture?.filter((p) => p.parent > 0) || [];
// 後方互換性のため、city タクソノミーも確認
const cityTerms = salon.city || [];

// 表示用の都道府県名とエリア名を取得
const prefectureName =
  prefectureTerms.length > 0 ? prefectureTerms[0].name : "";
const areaName =
  areaTerms.length > 0
    ? areaTerms[0].name
    : cityTerms.length > 0
      ? cityTerms[0].name
      : "";

// フィルタリング用のdata属性（親タームと子タームを分けて設定）
const prefectureSlugs = prefectureTerms.map((p) => p.slug).join(",");
const prefectureNames = prefectureTerms.map((p) => p.name).join(",");
const areaSlugs = areaTerms.map((a) => a.slug).join(",");
const areaNames = areaTerms.map((a) => a.name).join(",");
---

<div
  class="recruit-environment__salon-card"
  data-region={salon.region.map((r) => r.slug).join(",")}
  data-prefecture={prefectureSlugs ||
    salon.prefecture.map((p) => p.slug).join(",")}
  data-prefecture-name={prefectureNames ||
    salon.prefecture.map((p) => p.name).join(",")}
  data-area={areaSlugs ||
    salon.prefecture
      .filter((p) => p.parent > 0)
      .map((p) => p.slug)
      .join(",")}
  data-area-name={areaNames ||
    salon.prefecture
      .filter((p) => p.parent > 0)
      .map((p) => p.name)
      .join(",")}
  data-city={salon.city.map((c) => c.slug).join(",")}
  data-city-name={salon.city.map((c) => c.name).join(",")}
  data-jobs={salon.job_role.map((j) => j.slug).join(",")}
  data-jobs-name={salon.job_role.map((j) => j.name).join(",")}
  data-employment={salon.employment_type.map((e) => e.slug).join(",")}
  data-employment-name={salon.employment_type.map((e) => e.name).join(",")}
  data-hiring={salon.is_hiring ? "1" : "0"}
  data-title={salon.title}
  data-furigana={salon.furigana}
  data-access={salon.access}
>
  <img
    src={salon.thumb}
    alt={salon.title}
    class="recruit-environment__salon-image"
  />
  <div class="recruit-environment__salon-tags">
    {
      salon.employment_type.map((emp) => (
        <span
          class={`recruit-environment__salon-tag recruit-environment__salon-tag--${
            emp.slug === "fulltime"
              ? "full-time"
              : emp.slug === "parttime"
                ? "part-time"
                : emp.slug === "mid-career"
                  ? "mid-career"
                  : emp.slug === "new"
                    ? "new-graduate"
                    : emp.slug
          }`}
        >
          {emp.name}
        </span>
      ))
    }
  </div>
  <div class="recruit-environment__salon-content">
    <h4 class="recruit-environment__salon-name">
      {salon.title} 【{salon.furigana}】
    </h4>
    <div class="recruit-environment__salon-info">
      <div class="recruit-environment__salon-job">
        <img
          src="/images/icons/icn_content_cut.svg"
          alt="職種"
          class="recruit-environment__salon-icon"
        />
        <span
          >{
            salon.job_role && salon.job_role.length > 0
              ? salon.job_role.map((job) => job.name).join("・")
              : ""
          }</span
        >
      </div>
      <div class="recruit-environment__salon-location">
        <img
          src="/images/icons/icn_location_on.svg"
          alt="所在地"
          class="recruit-environment__salon-icon"
        />
        <span>
          {prefectureName}
          {prefectureName && areaName ? "・" : ""}
          {areaName}
        </span>
      </div>
      <div class="recruit-environment__salon-access">
        <img
          src="/images/icons/icn_directions_railway.svg"
          alt="アクセス"
          class="recruit-environment__salon-icon"
        />
        <span>{salon.access || "アクセス情報未設定"}</span>
      </div>
    </div>
    <button class="recruit-environment__salon-btn">
      <a href={salon.reservation_url}>求人に応募する</a>
    </button>
  </div>
</div>

<style>
  .recruit-environment__salon-card {
    background-color: white;
    border-radius: 10px;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    height: 428px;
  }

  .recruit-environment__salon-card h3 {
    margin-top: 0;
    margin-bottom: 0;
  }

  .recruit-environment__salon-card h4 {
    margin-top: 0;
    margin-bottom: 0;
  }

  .recruit-environment__salon-card p {
    margin-top: 0;
    margin-bottom: 0;
  }

  .recruit-environment__salon-card p {
    margin-top: 0;
    margin-bottom: 0;
  }

  .recruit-environment__salon-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .recruit-environment__salon-image {
    width: 100%;
    height: 159px;
    object-fit: cover;
  }

  .recruit-environment__salon-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 16px 16px 10px;
  }

  .recruit-environment__salon-tag {
    background-color: var(--color-beige);
    color: var(--color-black);
    padding: 0px 4px;
    border-radius: 4px;
    font-size: 16px;
    line-height: 1.5;
    font-weight: 200;
    font-family: var(--font-family-zenkaku);
  }

  .recruit-environment__salon-tag--new-graduate {
    background-color: #e3f3f5;
  }

  .recruit-environment__salon-tag--mid-career {
    background-color: #fff1e4;
  }

  /* 新卒/中途 表示色を調整 */
  .recruit-environment__salon-tag--new {
    background-color: #e3f3f5;
  }

  .recruit-environment__salon-tag--full-time {
    background-color: #faf4e8;
  }

  .recruit-environment__salon-tag--part-time {
    background-color: #effae8;
  }

  .recruit-environment__salon-tag--job {
    background-color: #e3f3f5;
  }

  .recruit-environment__salon-content {
    padding: 0 16px 16px;
    display: flex;
    flex-direction: column;
    height: calc(100% - 229px);
    gap: 10px;
    justify-content: space-between;
  }

  .recruit-environment__salon-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--color-black);
    margin-bottom: 12px;
    margin-top: 0;
    line-height: 1.25;
    font-family: var(--font-family-zenkaku);
  }

  .recruit-environment__salon-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 10px;
  }

  .recruit-environment__salon-job,
  .recruit-environment__salon-location,
  .recruit-environment__salon-access {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    color: #848383;
    line-height: 1;
    font-family: var(--font-family-zenkaku);
    font-weight: 700;
  }

  .recruit-environment__salon-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .recruit-environment__salon-btn {
    background-color: var(--color-white);
    color: var(--color-black);
    border: 1px solid var(--color-black);
    padding: 8px 16px;
    border-radius: 8px;
    font-family: var(--font-family-zenkaku);
    font-size: 16px;
    font-weight: 500;
    cursor: pointer;
    width: 100%;
    margin-top: auto;
    transition: all 0.3s ease;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .recruit-environment__salon-btn:hover {
    background-color: var(--color-black);
    color: var(--color-white);
  }

  .recruit-environment__salon-btn a {
    color: inherit;
    text-decoration: none;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
