---
export interface Props {
  videos: {
    id: number;
    title: string;
    video_url: string;
    thumbnail_url: string;
    link_url?: string;
  }[];
}

const { videos } = Astro.props;
---

<section class="bg-[#D2CABB] py-10 md:py-16">
  <div class="max-w-[1040px] mx-auto px-6">
    <h3 class="lg:!text-[32px] !text-[20px] font-normal !mb-4 text-[#3d3d3d]">
      littleで働くスタッフ
    </h3>

    <div
      class="video-scroll-container overflow-x-auto pb-6 -mx-6 px-6 md:mx-0 md:px-0"
    >
      <div class="flex gap-4 md:gap-6 min-w-max">
        {
          videos.map((video) => {
            const Tag = video.link_url ? "a" : "div";
            return (
              <Tag
                href={video.link_url || undefined}
                target={video.link_url ? "_blank" : undefined}
                rel={video.link_url ? "noopener noreferrer" : undefined}
                class={`video-card relative w-[180px] md:w-[280px] shrink-0 rounded-[6px] md:rounded-[10px] overflow-hidden bg-[#EAE8E3] ${video.link_url ? "block hover:opacity-90 transition-opacity cursor-pointer" : ""}`}
              >
                <div class="aspect-[9/16] w-full">
                  <video
                    src={video.video_url}
                    poster={video.thumbnail_url}
                    autoplay
                    muted
                    playsinline
                    loop
                    class="w-full h-full object-cover"
                  />
                </div>
              </Tag>
            );
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* 横スクロールバーを非表示にする（スワイプ・スクロール操作は可能） */
  .video-scroll-container {
    -ms-overflow-style: none; /* IE, Edge用 */
    scrollbar-width: none; /* Firefox用 */
  }
  .video-scroll-container::-webkit-scrollbar {
    display: none; /* Chrome, Safari用 */
  }
</style>
